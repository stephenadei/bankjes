# Amsterdam DSO-API key — verplicht vanaf najaar 2026, nu nog optioneel.
# Aanvragen: https://keys.api.data.amsterdam.nl/clients/v1/
AMSTERDAM_API_KEY=

# Mapillary access token — optioneel, voor straat-foto's in marker-popup.
# Aanvragen: https://www.mapillary.com/dashboard/developers
# Zonder token werkt de app gewoon, popup laat fotoblok weg.
MAPILLARY_TOKEN=

# OpenRouteService key — optioneel. Zonder key routeert de app via de open
# FOSSGIS-OSRM-instances (lopen/fietsen); een gratis key
# (https://openrouteservice.org/dev/) voegt het rolstoelprofiel (♿) toe.
ORS_API_KEY=
